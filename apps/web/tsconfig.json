{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "jsx": "preserve",
    "module": "ESNext",
    "noEmit": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@personal-os/core": [
        "../../packages/core/src/index.ts"
      ],
      "@personal-os/core/*": [
        "../../packages/core/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
