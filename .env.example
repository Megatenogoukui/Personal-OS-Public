# Public URL used by integrations and deployment links.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3020

# Primary persistence. Each deployment should use its own MongoDB database.
PERSONAL_OS_STORE_DRIVER=mongodb
MONGODB_URI=
MONGODB_DB=personal_os
MONGODB_COLLECTION=app_store
PERSONAL_OS_STORE_KEY=default

# Private dashboard access. Generate the secret key with: openssl rand -base64 32
PERSONAL_OS_ACCESS_PASSWORD=
PERSONAL_OS_SECRET_KEY=

# Separate secrets for full-store administration and iPhone finance imports.
PERSONAL_OS_ADMIN_SECRET=
FINANCE_IMPORT_SECRET=

# Optional Vercel Blob source used only by the migration script or legacy installs.
BLOB_READ_WRITE_TOKEN=
PERSONAL_OS_SOURCE_STORE_KEY=default

# Optional mutual-fund price service override.
MFAPI_BASE_URL=https://api.mfapi.in
